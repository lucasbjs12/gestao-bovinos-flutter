rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Cada usuário acessa apenas sua própria fazenda
    match /fazendas/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Usuário lê/cria seu próprio documento de assinatura
    match /usuarios/{uid} {
      allow read, create: if request.auth != null && request.auth.uid == uid;
      // Apenas admins escrevem em qualquer documento de usuário
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.isAdmin == true;
    }

  }
}
