rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function autenticado() {
      return request.auth != null;
    }

    function ehDono(uid) {
      return autenticado() && request.auth.uid == uid;
    }

    function ehAdmin() {
      return autenticado()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.isAdmin == true;
    }

    // Cobrança desativada por enquanto: sempre libera.
    // Quando ativar a monetização, troque o corpo pela versão comentada
    // e reative a AcessoBloqueadoScreen no app.dart.
    function assinaturaLiberada() {
      return true;
      // let u = get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
      // return u.isAdmin == true
      //   || (u.status == 'ativo' && (u.vencimento == null || u.vencimento > request.time));
    }

    // ── Multi-usuário por fazenda ─────────────────────────────────────────
    // O dono é reconhecido pela construção fazendaId == uid (compatível com
    // o app atual, mesmo sem doc de membro). Capataz vira membro via doc em
    // fazendas/{fazendaId}/membros/{uid}, criado pelo fluxo de convite.

    function ehDonoDaFazenda(fazendaId) {
      return autenticado() && request.auth.uid == fazendaId;
    }

    function ehMembro(fazendaId) {
      return autenticado() && (
        request.auth.uid == fazendaId
        || exists(/databases/$(database)/documents/fazendas/$(fazendaId)/membros/$(request.auth.uid))
      );
    }

    match /fazendas/{fazendaId} {
      // Doc da fazenda em si: membro lê; só o dono escreve.
      // delete fica fora da checagem de assinatura para a exclusão de conta
      // (LGPD) continuar funcionando mesmo com acesso bloqueado.
      allow get: if ehMembro(fazendaId) && assinaturaLiberada();
      allow create, update: if ehDonoDaFazenda(fazendaId) && assinaturaLiberada();
      allow delete: if ehDonoDaFazenda(fazendaId);

      // Coleções operacionais: qualquer membro lê e cria/edita; excluir é
      // ação de dono (baixas, exclusão de animais/invernadas e LGPD).
      // membros e atividades ficam FORA da lista de escrita — as regras
      // específicas abaixo valem para elas (em rules, permissões se somam).
      match /{colecao}/{docId} {
        allow get, list: if ehMembro(fazendaId) && assinaturaLiberada();
        allow create, update: if colecao in [
            'bovinos', 'invernadas', 'eventos_sanitarios',
            'movimentacoes', 'baixas_bovinos',
          ]
          && ehMembro(fazendaId) && assinaturaLiberada();
        allow delete: if ehDonoDaFazenda(fazendaId);
      }

      // Diário de atividades: membro registra em nome próprio; ninguém
      // edita (auditoria imutável); delete só via regra de dono acima (LGPD).
      match /atividades/{atividadeId} {
        allow create: if ehMembro(fazendaId)
          && assinaturaLiberada()
          && request.resource.data.autorUid == request.auth.uid;
        allow update: if false;
      }

      // Membros: só o dono gerencia; papel restrito aos valores conhecidos.
      // Ninguém (nem capataz) escala o próprio papel.
      match /membros/{membroUid} {
        allow create, update: if ehDonoDaFazenda(fazendaId)
          && request.resource.data.papel in ['dono', 'capataz'];
      }
    }

    match /usuarios/{uid} {
      // Dono lê o próprio doc; admin lê e lista todos (painel admin).
      allow get: if ehDono(uid) || ehAdmin();
      allow list: if ehAdmin();

      // Usuário cria o próprio doc obrigatoriamente sem privilégios —
      // impede signup direto com isAdmin: true ou status: 'ativo'.
      allow create: if ehDono(uid)
        && request.resource.data.isAdmin == false
        && request.resource.data.status == 'pendente';

      // Só admin altera assinatura (status, plano, vencimento, isAdmin).
      // O primeiro admin é promovido manualmente pelo console do Firebase.
      allow update, delete: if ehAdmin();
    }

  }
}
